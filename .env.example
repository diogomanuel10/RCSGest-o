# Copia este ficheiro para `.env` e preenche com os valores do teu projeto Supabase.
# Encontras estes valores no painel do Supabase em: Project Settings -> API
#
#   VITE_SUPABASE_URL      = "Project URL"
#   VITE_SUPABASE_ANON_KEY = "anon public" key
#
# A anon key é segura no cliente DESDE QUE o Row Level Security (RLS) esteja ativo.
# NUNCA uses aqui a service_role key.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Notificações push (PWA). Chave PÚBLICA VAPID — segura no cliente.
# Gera o par de chaves com: npx web-push generate-vapid-keys
# (a chave PRIVADA fica só nos secrets do Supabase, nunca aqui.)
# Ver supabase/functions/send-push/README.md
VITE_VAPID_PUBLIC_KEY=
